{
  "name": "taurscribe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:macos": "bun scripts/build-macos.ts",
    "build:windows": "bun scripts/build-windows.ts --bundles nsis",
    "build:windows-portable": "npm run tauri build -- --target x86_64-pc-windows-msvc --config '{\"bundle\":{\"targets\":[\"nsis\"],\"windows\":{\"nsis\":{\"installMode\":\"portable\"}}}}'",
    "check": "cd src-tauri && cargo check",
    "reset": "rm -rf ~/Library/Application\\ Support/taurscribe/settings.json ~/Library/Application\\ Support/Taurscribe/transcripts.db && echo 'Settings and history reset.'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "canvas-confetti": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
