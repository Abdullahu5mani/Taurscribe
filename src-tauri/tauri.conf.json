{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taurscribe",
  "version": "0.1.0",
  "identifier": "taurscribe",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "beforeBundleCommand": "bun scripts/copy-dlls.ts && bun scripts/bundle-macos-dylibs.ts",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Taurscribe",
        "width": 901,
        "height": 850,
        "minWidth": 400,
        "minHeight": 200,
        "decorations": false,
        "visible": false,
        "devtools": true
      },
      {
        "label": "overlay",
        "url": "index.html#overlay",
        "width": 80,
        "height": 80,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../target/release/DirectML.dll": ".",
      "../target/release/ggml-base.dll": ".",
      "../target/release/ggml-cpu.dll": ".",
      "../target/release/ggml.dll": ".",
      "../target/release/llama.dll": ".",
      "../target/release/onnxruntime_providers_cuda.dll": ".",
      "../target/release/onnxruntime_providers_shared.dll": ".",
      "../target/release/onnxruntime_providers_tensorrt.dll": "."
    },
    "macOS": {
      "minimumSystemVersion": "13.4",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
