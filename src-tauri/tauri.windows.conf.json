{
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Taurscribe",
        "width": 780,
        "height": 730,
        "minWidth": 400,
        "minHeight": 200,
        "decorations": false,
        "visible": false,
        "devtools": true
      },
      {
        "label": "overlay",
        "url": "index.html#overlay",
        "width": 228,
        "height": 42,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "resizable": true,
        "focus": false
      }
    ]
  },
  "bundle": {
    "resources": {
      "target/release/llama.dll": "./llama.dll",
      "target/release/ggml.dll": "./ggml.dll",
      "target/release/ggml-base.dll": "./ggml-base.dll",
      "target/release/ggml-cpu.dll": "./ggml-cpu.dll",
      "target/release/onnxruntime_providers_shared.dll": "./onnxruntime_providers_shared.dll",
      "target/release/onnxruntime_providers_cuda.dll": "./onnxruntime_providers_cuda.dll",
      "target/release/onnxruntime_providers_tensorrt.dll": "./onnxruntime_providers_tensorrt.dll",
      "target/release/DirectML.dll": "./DirectML.dll"
    }
  }
}
